---
---

<section id="hero">
  <div class="hero-grain"></div>
  <div class="hero-orb hero-orb-1"></div>
  <div class="hero-orb hero-orb-2"></div>
  <div class="hero-orb hero-orb-3"></div>

  <!-- Bolt canvas — fixed, full viewport, behind arcs -->
  <canvas id="heroFxCanvas"></canvas>

  <!-- FX anchor — fixed at viewport center-upper -->
  <div class="hero-fx-wrap" id="heroFxWrap">

    <!--
      5 partial arcs, each starting at a large radius far from the orb.
      JS will fly them inward to r=90 (orb rim), then merge into one white stroke.
      Initial r values match arcData.startR in JS.
      dasharray = dashFrac * 2πr  for each starting radius.
    -->
    <div class="fx-arc" id="fxArcWrap1">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle id="fxCircle1" cx="0" cy="0" r="255" fill="none"
          stroke="rgba(18,220,140,0)" stroke-width="1.5"
          stroke-linecap="round" stroke-dasharray="481 1121"/>
      </svg>
    </div>
    <div class="fx-arc" id="fxArcWrap2">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle id="fxCircle2" cx="0" cy="0" r="215" fill="none"
          stroke="rgba(18,220,140,0)" stroke-width="1.5"
          stroke-linecap="round" stroke-dasharray="324 1027"/>
      </svg>
    </div>
    <div class="fx-arc" id="fxArcWrap3">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle id="fxCircle3" cx="0" cy="0" r="188" fill="none"
          stroke="rgba(18,220,140,0)" stroke-width="1.5"
          stroke-linecap="round" stroke-dasharray="401 779"/>
      </svg>
    </div>
    <div class="fx-arc" id="fxArcWrap4">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle id="fxCircle4" cx="0" cy="0" r="238" fill="none"
          stroke="rgba(18,220,140,0)" stroke-width="1"
          stroke-linecap="round" stroke-dasharray="299 1196"/>
      </svg>
    </div>
    <div class="fx-arc" id="fxArcWrap5">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle id="fxCircle5" cx="0" cy="0" r="272" fill="none"
          stroke="rgba(18,220,140,0)" stroke-width="1"
          stroke-linecap="round" stroke-dasharray="274 1435"/>
      </svg>
    </div>
    <!-- 4 extra thinner arcs for forming density + blink effect -->
    <div class="fx-arc" id="fxArcWrap6">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle id="fxCircle6" cx="0" cy="0" r="220" fill="none"
          stroke="rgba(18,220,140,0)" stroke-width="0.8"
          stroke-linecap="round" stroke-dasharray="105 1277"/>
      </svg>
    </div>
    <div class="fx-arc" id="fxArcWrap7">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle id="fxCircle7" cx="0" cy="0" r="295" fill="none"
          stroke="rgba(18,220,140,0)" stroke-width="0.8"
          stroke-linecap="round" stroke-dasharray="140 1713"/>
      </svg>
    </div>
    <div class="fx-arc" id="fxArcWrap8">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle id="fxCircle8" cx="0" cy="0" r="255" fill="none"
          stroke="rgba(18,220,140,0)" stroke-width="0.8"
          stroke-linecap="round" stroke-dasharray="60 1542"/>
      </svg>
    </div>
    <div class="fx-arc" id="fxArcWrap9">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle id="fxCircle9" cx="0" cy="0" r="335" fill="none"
          stroke="rgba(18,220,140,0)" stroke-width="0.8"
          stroke-linecap="round" stroke-dasharray="175 1930"/>
      </svg>
    </div>

    <!-- Soft glow halo behind the white ring -->
    <div class="fx-arc" id="fxGlowArc">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle id="fxGlowCircle" cx="0" cy="0" r="120" fill="none"
          stroke="rgba(255,255,255,0)" stroke-width="6"
          stroke-linecap="round" stroke-dasharray="754 0"/>
      </svg>
    </div>

    <!-- Vector ring — visible from page load, fades on boop -->
    <div class="orb-vector-ring" id="orbVectorRing">
      <svg viewBox="0 0 1 1" width="1" height="1" overflow="visible">
        <circle cx="0" cy="0" r="120" fill="none"
          stroke="rgba(255,255,255,0.22)" stroke-width="1"
          stroke-dasharray="4 6" stroke-linecap="round"/>
      </svg>
    </div>

    <!-- Orb formation FX -->
    <div class="orb-ripple-el" id="orbRipple1"></div>
    <div class="orb-ripple-el" id="orbRipple2"></div>
    <div class="orb-ripple-el" id="orbRipple3"></div>
    <div class="orb-flash-el"  id="orbFlashEl"></div>

    <!-- Orb -->
    <div class="hero-logo-orb" id="heroLogoOrb">
      <img src="/images/logo.svg" alt="Rafael Amezcua logo" class="hero-headshot" />
    </div>

  </div>

  <div class="hero-scroll"><div class="hero-scroll-line"></div></div>

  <div class="hero-content">
    <div class="hero-badge" id="heroBadge">
      <span class="hero-badge-dot"></span>
      Open to Opportunities
    </div>
    <div class="hero-line" id="heroLine"></div>
    <p class="hero-eyebrow" id="heroEyebrow">Navy Veteran · USD 2028 · San Diego</p>
    <h1 class="hero-name" id="heroName">
      Rafael<br /><span class="outline">Amezcua</span>
    </h1>
    <p class="hero-tagline">Marketing meets product. Strategy meets execution.</p>
    <p class="hero-sub" id="heroSub">
      Navy veteran and marketing student building at the intersection of brand, design, and technology.
    </p>
    <div class="hero-actions">
      <a href="#projects" class="hero-cta"       id="heroCta">View My Work →</a>
      <a href="#contact"  class="hero-cta-ghost" id="heroCtaGhost">Get In Touch</a>
    </div>
    <div class="hero-credentials">
      <span class="cred-badge">U.S. Navy Veteran</span>
      <span class="cred-badge">USD Marketing 2028</span>
      <span class="cred-badge">Founder, Nymbus</span>
    </div>
  </div>
</section>

<style is:global>
@keyframes nameGlowPulse{
  0%  {text-shadow:0 4px 40px rgba(0,0,0,0.6),0 2px 8px rgba(0,0,0,0.4);}
  18% {text-shadow:0 0 28px rgba(18,220,140,0.75),0 0 60px rgba(18,163,114,0.45),0 0 110px rgba(18,163,114,0.2),0 4px 40px rgba(0,0,0,0.5);}
  100%{text-shadow:0 4px 40px rgba(0,0,0,0.6),0 2px 8px rgba(0,0,0,0.4);}
}
.orb-name-glow{animation:nameGlowPulse 3s ease-out forwards!important;}

/* Vector ring placeholder */
.orb-vector-ring{
  position:absolute;top:0;left:0;
  pointer-events:none;
  transition:opacity 0.5s ease-out;
}

/* Orb formation: inner flash */
.orb-flash-el{
  position:absolute;width:240px;height:240px;border-radius:50%;
  top:-120px;left:-120px;pointer-events:none;
}
@keyframes orbFlashPop{
  0%  {background:rgba(255,255,255,0);box-shadow:0 0 0 rgba(255,255,255,0);}
  7%  {background:rgba(255,255,255,0.30);box-shadow:0 0 80px rgba(255,255,255,0.95),0 0 220px rgba(255,255,255,0.35);}
  100%{background:rgba(255,255,255,0);box-shadow:0 0 0 rgba(255,255,255,0);}
}
.orb-flash-el.fire{animation:orbFlashPop 2s ease-out forwards;}

/* Orb formation: expanding ripple rings */
.orb-ripple-el{
  position:absolute;border-radius:50%;
  border:1.5px solid rgba(255,255,255,0);
  width:240px;height:240px;top:-120px;left:-120px;pointer-events:none;
}
@keyframes orbRippleOut{
  0%  {width:240px;height:240px;top:-120px;left:-120px;opacity:0.85;border-color:rgba(255,255,255,0.7);}
  100%{width:720px;height:720px;top:-360px;left:-360px;opacity:0;}
}
.orb-ripple-el.fire{animation:orbRippleOut 1.8s cubic-bezier(0.1,0.75,0.25,1) forwards;}
</style>

<script is:inline>
(function () {
  var wrap  = document.getElementById('heroFxWrap');
  var hero  = document.getElementById('hero');
  var orb   = document.getElementById('heroLogoOrb');
  var cnv   = document.getElementById('heroFxCanvas');
  if (!wrap || !hero || !orb) return;

  /* ── CANVAS ── */
  var ctx = cnv ? cnv.getContext('2d') : null;
  function resizeCnv() { if (cnv) { cnv.width = window.innerWidth; cnv.height = window.innerHeight; } }
  resizeCnv();
  window.addEventListener('resize', resizeCnv);

  var ax, ay;
  function updateAnchor() { ax = window.innerWidth * 0.5; ay = window.innerHeight * 0.26; }
  updateAnchor();
  window.addEventListener('resize', updateAnchor);

  /* ── SCROLL PHASE BOUNDARIES (fraction of ANIM_RANGE) ── */
  var ANIM_RANGE  = window.innerHeight * 0.65;
  var P_ARC_IN    = 0.04;  // arcs start appearing
  var P_FLY_END   = 0.35;  // arcs reach orb rim
  var P_ORBIT_END = 0.50;  // orb solid — collapse begins
  var P_COLLAPSE  = 0.92;  // singularity — everything consumed

  // Tracks actual orb radius as it shrinks; shared by arcs, shine, tracer, comet
  var curOrbR = 120;

  // Singularity flash state
  var singularityFired = false;
  var singularityAlpha = 0;

  /* ── ARC DATA ── */
  var ORB_R  = 120; // half of 240px orb
  var TWO_PI = Math.PI * 2;
  var arcData = [
    // Staggered appearance: each arc flies in one by one as user scrolls
    { wId:'fxArcWrap1', cId:'fxCircle1', startR:340, angle:0,   baseSpd: 0.28, dashFrac:0.30, ga:0.75, bo:0.0, appearAt:0.02 },
    { wId:'fxArcWrap2', cId:'fxCircle2', startR:286, angle:72,  baseSpd:-0.36, dashFrac:0.24, ga:0.70, bo:1.1, appearAt:0.06 },
    { wId:'fxArcWrap3', cId:'fxCircle3', startR:250, angle:144, baseSpd: 0.22, dashFrac:0.34, ga:0.65, bo:2.3, appearAt:0.10 },
    { wId:'fxArcWrap4', cId:'fxCircle4', startR:317, angle:216, baseSpd:-0.20, dashFrac:0.20, ga:0.60, bo:3.7, appearAt:0.14 },
    { wId:'fxArcWrap5', cId:'fxCircle5', startR:362, angle:288, baseSpd: 0.16, dashFrac:0.16, ga:0.55, bo:5.2, appearAt:0.18 },
    { wId:'fxArcWrap6', cId:'fxCircle6', startR:293, angle:36,  baseSpd: 0.42, dashFrac:0.13, ga:0.52, bo:0.8, appearAt:0.22 },
    { wId:'fxArcWrap7', cId:'fxCircle7', startR:393, angle:108, baseSpd:-0.30, dashFrac:0.18, ga:0.48, bo:2.0, appearAt:0.26 },
    { wId:'fxArcWrap8', cId:'fxCircle8', startR:340, angle:180, baseSpd: 0.52, dashFrac:0.08, ga:0.45, bo:4.4, appearAt:0.30 },
    { wId:'fxArcWrap9', cId:'fxCircle9', startR:447, angle:252, baseSpd:-0.24, dashFrac:0.15, ga:0.42, bo:1.6, appearAt:0.34 },
  ];
  var arcs = arcData.map(function (d) {
    return { wrap:document.getElementById(d.wId), circle:document.getElementById(d.cId),
             r:d.startR, startR:d.startR, angle:d.angle, baseSpd:d.baseSpd,
             dashFrac:d.dashFrac, ga:d.ga, opacity:0, bo:d.bo, appearAt:d.appearAt };
  });

  /* ── CHROMA + GLOW ELEMENTS ── */
  var chromaR  = document.getElementById('fxChromaR');
  var chromaC  = document.getElementById('fxChromaC');
  var glowArc  = document.getElementById('fxGlowArc');
  var chromaRc = document.getElementById('fxChromaCircleR');
  var chromaCc = document.getElementById('fxChromaCircleC');
  var glowCirc = document.getElementById('fxGlowCircle');
  var logoImg  = document.querySelector('#heroLogoOrb .hero-headshot');
  var survivorCircle = document.getElementById('fxCircle1');

  /* ── ORB FORMATION FX ELEMENTS ── */
  var orbRipple1   = document.getElementById('orbRipple1');
  var orbRipple2   = document.getElementById('orbRipple2');
  var orbRipple3   = document.getElementById('orbRipple3');
  var orbFlashEl   = document.getElementById('orbFlashEl');
  var orbVectorRing = document.getElementById('orbVectorRing');

  /* ── HELPERS ── */
  function lerp(a, b, t)     { return a + (b - a) * t; }
  function clamp01(v)        { return v < 0 ? 0 : v > 1 ? 1 : v; }
  function easeOut3(t)       { return 1 - Math.pow(1 - t, 3); }
  function easeIn2(t)        { return t * t; }
  function pt(p, lo, hi)     { return clamp01((p - lo) / (hi - lo)); }

  /* ── PER-ARC UPDATE (scroll-driven) ── */
  function updateArc(arc, dt, p) {
    if (!arc.wrap || !arc.circle) return;
    if (p < arc.appearAt) { arc.wrap.style.opacity = '0'; return; }

    var velBoost = Math.min(4, 1 + Math.abs(scrollVel) * 0.14);

    if (p < P_ORBIT_END) {
      // ── FLY-IN: spiral from startR → ORB_R ──
      var flyP    = pt(p, arc.appearAt, P_FLY_END);
      arc.r       = lerp(arc.startR, ORB_R, easeOut3(flyP));
      var radMul  = arc.startR / Math.max(arc.r, ORB_R);
      arc.angle  += arc.baseSpd * dt * radMul * velBoost;

      arc.opacity = pt(p, arc.appearAt, arc.appearAt + 0.05);
      // Blink ramps from slow → frantic as arcs arrive
      var blinkFreq = lerp(2.5, 26, pt(p, 0.02, P_FLY_END));
      arc.opacity  *= 0.15 + 0.85 * Math.abs(Math.sin(now * 0.001 * Math.PI * blinkFreq + arc.bo));
    } else {
      // ── COLLAPSE: follow curOrbR inward, angular momentum spins up wildly ──
      var stagger = arc.appearAt * 0.12;
      var colP    = pt(p, P_ORBIT_END, P_COLLAPSE - stagger);
      arc.r       = Math.max(0.3, curOrbR);
      var angMom  = Math.pow(ORB_R / Math.max(curOrbR, 1), 1.5);
      arc.angle  += arc.baseSpd * dt * Math.min(angMom, 80) * velBoost;
      arc.opacity = Math.max(0, 1 - Math.pow(colP, 1.4));
    }

    var strokeA  = arc.ga * arc.opacity;
    var circ     = TWO_PI * arc.r;
    arc.circle.setAttribute('r', arc.r.toFixed(2));
    arc.circle.setAttribute('stroke-dasharray',
      (arc.dashFrac * circ).toFixed(1) + ' ' + ((1 - arc.dashFrac) * circ).toFixed(1));
    arc.circle.setAttribute('stroke', 'rgba(255,255,255,' + strokeA.toFixed(3) + ')');
    arc.wrap.style.transform = 'rotate(' + arc.angle.toFixed(2) + 'deg)';
    arc.wrap.style.opacity   = arc.opacity.toFixed(3);
  }

  /* ── ORB FORMATION BURST ── */
  var formParticles = [];
  var orbBurstFired = false;
  var shineAngle    = 0;
  var shineOp       = 0;
  var shineActive   = false;

  function triggerOrbBurst() {
    var count = 56;
    for (var i = 0; i < count; i++) {
      var a      = (i / count) * Math.PI * 2;
      var jitter = (Math.random() - 0.5) * 0.35;
      var speed  = 2.5 + Math.random() * 4;
      formParticles.push({
        x: ax + Math.cos(a) * ORB_R,
        y: ay + Math.sin(a) * ORB_R,
        vx: Math.cos(a + jitter) * speed,
        vy: Math.sin(a + jitter) * speed,
        alpha: 0.95 + Math.random() * 0.05,
        size:  1.2 + Math.random() * 2.2,
      });
    }
  }

  function renderFormParticles() {
    if (!ctx) return;
    formParticles = formParticles.filter(function (fp) { return fp.alpha > 0; });
    formParticles.forEach(function (fp) {
      fp.x += fp.vx; fp.y += fp.vy;
      fp.vx *= 0.94; fp.vy *= 0.94;
      ctx.beginPath();
      ctx.arc(fp.x, fp.y, Math.max(0.2, fp.size * fp.alpha), 0, Math.PI * 2);
      ctx.fillStyle   = 'rgba(255,255,255,' + fp.alpha.toFixed(3) + ')';
      ctx.shadowBlur  = 10;
      ctx.shadowColor = 'rgba(255,255,255,0.7)';
      ctx.fill();
      ctx.shadowBlur  = 0;
      fp.alpha -= 0.014;
    });
  }

  function renderShine() {
    if (!ctx || shineOp <= 0) return;
    var arc  = Math.PI * 0.55; // ~100° sweep
    var segs = 32;
    for (var i = 0; i < segs; i++) {
      var t      = i / segs;
      var a1     = shineAngle + t * arc;
      var a2     = a1 + arc / segs + 0.003;
      var bright = Math.sin(Math.PI * t); // bell curve — brightest at center
      ctx.beginPath();
      ctx.arc(ax, ay, curOrbR, a1, a2);
      ctx.strokeStyle = 'rgba(255,255,255,' + (shineOp * bright * 0.88).toFixed(3) + ')';
      ctx.lineWidth   = 3 + bright * 10; // thicker at center for lens-flare look
      ctx.lineCap     = 'round';
      ctx.stroke();
    }
    shineAngle += 0.006; // slow continuous orbit
  }

  /* ── TRACER LIGHT — one full orbit post-formation ── */
  var tracerProgress = 0;
  var tracerActive   = false;
  var tracerStartAngle = 0;

  function startTracer() {
    tracerProgress   = 0;
    tracerStartAngle = arcs[0] ? arcs[0].angle * Math.PI / 180 : 0;
    tracerActive     = true;
  }

  function renderTracer(dt) {
    if (!ctx || !tracerActive) return;
    // Speed ramps from slow crawl → fast as collapse deepens
    var collapseDepth = pt(cometP, P_ORBIT_END, P_COLLAPSE);
    var orbitSpeed    = lerp(0.0004, 0.0028, easeIn2(collapseDepth));
    tracerProgress    = Math.min(1, tracerProgress + dt * orbitSpeed);
    if (tracerProgress >= 1) { tracerActive = false; return; }

    var a   = tracerStartAngle + tracerProgress * Math.PI * 2;
    var tx  = ax + Math.cos(a) * curOrbR;
    var ty  = ay + Math.sin(a) * curOrbR;
    var fad = Math.min(1, tracerProgress * 6) * (1 - Math.pow(tracerProgress, 3)); // ease in + fade out

    // Trail — fading arc behind the head
    var trailLen  = Math.PI * 0.30;
    var trailSegs = 24;
    for (var i = 0; i < trailSegs; i++) {
      var t  = i / trailSegs;
      var ta = a - trailLen * (1 - t);
      var trx = ax + Math.cos(ta) * curOrbR;
      var trY = ay + Math.sin(ta) * curOrbR;
      ctx.beginPath();
      ctx.arc(trx, trY, 1.5 * t, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255,255,255,' + (fad * t * 0.55).toFixed(3) + ')';
      ctx.fill();
    }

    // Bright core + radial bloom
    var g = ctx.createRadialGradient(tx, ty, 0, tx, ty, 22);
    g.addColorStop(0, 'rgba(255,255,255,' + fad.toFixed(3) + ')');
    g.addColorStop(0.3, 'rgba(255,255,255,' + (fad * 0.5).toFixed(3) + ')');
    g.addColorStop(1,   'rgba(255,255,255,0)');
    ctx.beginPath();
    ctx.arc(tx, ty, 22, 0, Math.PI * 2);
    ctx.fillStyle = g;
    ctx.fill();

    ctx.beginPath();
    ctx.arc(tx, ty, 2.5, 0, Math.PI * 2);
    ctx.fillStyle   = 'rgba(255,255,255,' + fad.toFixed(3) + ')';
    ctx.shadowBlur  = 24;
    ctx.shadowColor = 'rgba(255,255,255,0.9)';
    ctx.fill();
    ctx.shadowBlur  = 0;
  }

  function checkOrbFormation(orbOp) {
    if (orbOp > 0.92 && !orbBurstFired) {
      orbBurstFired = true;
      // Eject all orbiting build-ring particles outward into the burst
      buildRing.forEach(function (bp) {
        var x    = ax + Math.cos(bp.angle) * bp.r;
        var y    = ay + Math.sin(bp.angle) * bp.r;
        var outA = Math.atan2(y - ay, x - ax);
        var spd  = 3 + Math.random() * 4.5;
        formParticles.push({ x: x, y: y,
          vx: Math.cos(outA) * spd, vy: Math.sin(outA) * spd,
          alpha: bp.alpha, size: bp.size * 1.5 });
      });
      buildRing = [];
      triggerOrbBurst();
      // Staggered ripple rings
      [orbRipple1, orbRipple2, orbRipple3].forEach(function (r, i) {
        if (!r) return;
        setTimeout(function () {
          r.classList.remove('fire'); void r.offsetWidth; r.classList.add('fire');
        }, i * 210);
      });
      // Inner flash
      if (orbFlashEl) {
        orbFlashEl.classList.remove('fire'); void orbFlashEl.offsetWidth; orbFlashEl.classList.add('fire');
      }
      shineActive = true;
      // Start tracer after burst settles
      setTimeout(startTracer, 280);
    }
    if (orbOp < 0.05) {
      orbBurstFired = false; shineActive = false; shineOp = 0;
      tracerActive = false; singularityFired = false; singularityAlpha = 0;
    }
    if (shineActive) shineOp = Math.min(1, shineOp + 0.022);
  }

  /* ── ORB: forms then collapses like a black hole ── */
  var orbBreathing = false;
  function updateOrb(p) {
    if (p < P_ORBIT_END) {
      // Forming phase: ghost → solid
      var formP = pt(p, P_FLY_END, P_ORBIT_END);
      var orbOp = easeOut3(formP);
      curOrbR = ORB_R;
      orb.style.opacity     = orbOp.toFixed(3);
      orb.style.transform   = 'translate(-50%,-50%)';
      orb.style.borderColor = 'rgba(255,255,255,' + lerp(0.08, 0.28, formP).toFixed(3) + ')';
      if (orbOp > 0.92 && !orbBreathing) {
        orbBreathing = true;
        orb.classList.add('orb-breathing');
        triggerNameGlow();
      }
      checkOrbFormation(orbOp);
    } else {
      // Collapse phase: shrink to singularity
      if (orbBreathing) { orbBreathing = false; orb.classList.remove('orb-breathing'); }
      var colP  = pt(p, P_ORBIT_END, P_COLLAPSE);
      var scale = Math.max(0, 1 - easeIn2(colP));
      curOrbR   = Math.max(0, ORB_R * scale);
      orb.style.transform = 'translate(-50%,-50%) scale(' + scale.toFixed(4) + ')';
      orb.style.opacity   = scale > 0.03 ? '1' : '0';
      // Singularity flash when fully consumed
      if (scale <= 0.03 && !singularityFired) {
        singularityFired = true;
        singularityAlpha = 1.0;
      }
    }
    // Reset on scroll back to top
    if (p < 0.04) {
      curOrbR = ORB_R; singularityFired = false; singularityAlpha = 0;
      if (orbBreathing) { orbBreathing = false; orb.classList.remove('orb-breathing'); }
    }
  }

  /* ── SPARK BURST (B) ── */
  var sparks = [];
  function triggerSparks() {
    for (var i = 0; i < 22; i++) {
      var angle = Math.random() * Math.PI * 2;
      var speed = 2 + Math.random() * 4;
      sparks.push({
        x: ax, y: ay,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed - Math.random() * 1.5,
        alpha: 0.9 + Math.random() * 0.1,
        size:  1.2 + Math.random() * 2,
      });
    }
  }
  function renderSparks() {
    sparks = sparks.filter(function (s) { return s.alpha > 0; });
    sparks.forEach(function (s) {
      s.x  += s.vx;  s.y  += s.vy;
      s.vy += 0.10;  s.vx *= 0.96;  // gravity + drag
      ctx.beginPath();
      ctx.arc(s.x, s.y, Math.max(0.2, s.size * s.alpha), 0, Math.PI * 2);
      ctx.fillStyle   = 'rgba(40,220,150,' + s.alpha.toFixed(3) + ')';
      ctx.shadowBlur  = 6;
      ctx.shadowColor = 'rgba(18,163,114,0.8)';
      ctx.fill();
      ctx.shadowBlur  = 0;
      s.alpha -= 0.016;
    });
  }

  /* ── NAME GLOW (C) ── */
  var heroName       = document.getElementById('heroName');
  var nameGlowFired  = false;
  function triggerNameGlow() {
    if (!heroName || nameGlowFired) return;
    nameGlowFired = true;
    heroName.classList.add('orb-name-glow');
    setTimeout(function () { heroName.classList.remove('orb-name-glow'); nameGlowFired = false; }, 3000);
  }

  /* ── SHOCKWAVE (fires once when arcs arrive) ── */
  var swFired = false;
  function checkShockwave(p) {
    if (p >= P_FLY_END && !swFired) {
      swFired = true;
      triggerSparks(); // sparks on impact
    }
    if (p < P_FLY_END * 0.88) { swFired = false; nameGlowFired = false; }
  }

  /* ── GLOW HALO — tracks collapsing orb, always called to prevent stuck stroke ── */
  function updateChroma(p, arc0Angle) {
    if (p < P_ORBIT_END) {
      // Before collapse: keep glow invisible
      if (glowCirc) glowCirc.setAttribute('stroke', 'rgba(255,255,255,0)');
      return;
    }
    var glowOp = 1 - pt(p, P_COLLAPSE - 0.15, P_COLLAPSE);
    if (glowArc)  glowArc.style.transform = 'rotate(' + arc0Angle.toFixed(2) + 'deg)';
    if (glowCirc) {
      glowCirc.setAttribute('r', Math.max(0, curOrbR).toFixed(2));
      glowCirc.setAttribute('stroke', 'rgba(255,255,255,' + (glowOp * 0.10).toFixed(3) + ')');
    }
  }

  /* ── SINGULARITY FLASH ── */
  function renderSingularity() {
    if (!ctx || singularityAlpha <= 0) return;
    var g = ctx.createRadialGradient(ax, ay, 0, ax, ay, 120);
    g.addColorStop(0,    'rgba(255,255,255,' + singularityAlpha.toFixed(3) + ')');
    g.addColorStop(0.20, 'rgba(255,255,255,' + (singularityAlpha * 0.55).toFixed(3) + ')');
    g.addColorStop(1,    'rgba(255,255,255,0)');
    ctx.beginPath();
    ctx.arc(ax, ay, 120, 0, Math.PI * 2);
    ctx.fillStyle = g;
    ctx.fill();
    singularityAlpha = Math.max(0, singularityAlpha - 0.016);
  }

  /* ── CANVAS RENDER PASS ── */
  var renderDt = 16;
  function renderBolts() {
    if (!ctx) return;
    ctx.clearRect(0,0,cnv.width,cnv.height);
    renderSparks();        // arc-arrival sparks
    renderBuildRing();     // orbital build-up particles
    renderFormParticles(); // orb formation burst
    renderShine();         // orb ring shine sweep
    renderTracer(renderDt); // post-formation tracer orbit
    renderSingularity();   // final flash when consumed
  }

  /* ── MAIN LOOP ── */
  /* ── COMET TAIL (E) ── */
  var cometP = 0;
  function renderCometTail() {
    if (!ctx || cometP < P_ORBIT_END || curOrbR < 2) return;
    var headRad = arcs[0].angle * Math.PI / 180;
    var tailLen = Math.PI * 0.55;
    var segs    = 35;
    var fade    = 1 - pt(cometP, P_COLLAPSE - 0.12, P_COLLAPSE); // fades at end
    for (var i = 0; i < segs; i++) {
      var t  = i / segs;
      var a1 = headRad - tailLen + t * tailLen;
      var a2 = a1 + tailLen / segs + 0.002;
      ctx.beginPath();
      ctx.arc(ax, ay, curOrbR, a1, a2);
      ctx.strokeStyle = 'rgba(255,255,255,' + (t * 0.70 * fade).toFixed(3) + ')';
      ctx.lineWidth   = 2.5 * (0.4 + 0.6 * t);
      ctx.lineCap     = 'round';
      ctx.stroke();
    }
  }

  /* ── ORBITAL BUILD-UP RING ── */
  var buildRing       = [];
  var buildSpawnTimer = 0;

  function updateBuildRing(dt, p) {
    if (p < 0.02) { buildRing = []; buildSpawnTimer = 0; return; }

    if (p < P_ORBIT_END) {
      // Spawn interval ramps from 320ms → 14ms as arcs close in
      var spawnInterval = lerp(320, 14, pt(p, 0.02, P_FLY_END));
      buildSpawnTimer += dt;
      while (buildSpawnTimer >= spawnInterval) {
        buildSpawnTimer -= spawnInterval;
        var a   = Math.random() * Math.PI * 2;
        var r   = lerp(arcs[0].startR, ORB_R * 1.08, easeOut3(pt(p, 0.02, P_FLY_END)));
        var dir = Math.random() > 0.5 ? 1 : -1;
        buildRing.push({ angle: a, r: r, dir: dir, alpha: 0.0, size: 0.6 + Math.random() * 1.3 });
      }
      if (buildRing.length > 320) buildRing.splice(0, buildRing.length - 320);
      var orbitSpeed = lerp(0.003, 0.020, pt(p, 0.02, P_FLY_END));
      buildRing.forEach(function (bp) {
        bp.angle += bp.dir * orbitSpeed * dt;
        bp.alpha  = Math.min(0.80, bp.alpha + 0.06);
      });
    } else {
      // Collapse: particles spiral inward with increasing angular momentum
      var angMom      = Math.pow(ORB_R / Math.max(curOrbR, 1), 1.2);
      var inwardPull  = lerp(0.05, 4, pt(p, P_ORBIT_END, P_COLLAPSE));
      buildRing.forEach(function (bp) {
        bp.angle += bp.dir * 0.018 * Math.min(angMom, 40) * dt;
        bp.r      = Math.max(0, bp.r - inwardPull * (dt / 16));
        if (bp.r < curOrbR * 0.4) bp.alpha -= 0.06;
      });
      buildRing = buildRing.filter(function (bp) { return bp.alpha > 0; });
    }
  }

  function renderBuildRing() {
    if (!ctx || buildRing.length === 0) return;
    buildRing.forEach(function (bp) {
      var x = ax + Math.cos(bp.angle) * bp.r;
      var y = ay + Math.sin(bp.angle) * bp.r;
      ctx.beginPath();
      ctx.arc(x, y, bp.size, 0, Math.PI * 2);
      ctx.fillStyle   = 'rgba(255,255,255,' + bp.alpha.toFixed(3) + ')';
      ctx.shadowBlur  = 5;
      ctx.shadowColor = 'rgba(255,255,255,0.6)';
      ctx.fill();
      ctx.shadowBlur  = 0;
    });
  }

  var lastTs    = 0;
  var prevSY    = 0;
  var scrollVel = 0;
  var now       = 0; // updated each tick, used for blink sine

  function tick(ts) {
    var dt = Math.min(ts - lastTs, 50);
    lastTs = ts;

    now = ts;
    renderDt = dt;
    renderBolts();
    renderCometTail(); // E

    var scrollY    = window.scrollY;
    scrollVel      = scrollY - prevSY;   // H: velocity this frame
    prevSY         = scrollY;
    var heroBottom = hero.offsetTop + hero.offsetHeight;
    var p          = Math.min(1, scrollY / ANIM_RANGE);
    cometP         = p; // share with renderCometTail

    if (scrollY > heroBottom) {
      wrap.style.display = 'none';
      if (cnv) cnv.style.display = 'none';
    } else {
      wrap.style.display = '';
      if (cnv) cnv.style.display = '';

      // Fade FX wrap out after singularity
      wrap.style.opacity = (1 - pt(p, P_COLLAPSE, 1.0)).toFixed(3);
      if (cnv) cnv.style.opacity = wrap.style.opacity;

      // Orbital build-up ring
      updateBuildRing(dt, p);

      // Motion blur on arcs — proportional to scroll velocity
      var blurPx = Math.min(5, Math.abs(scrollVel) * 0.22).toFixed(1);
      var blurVal = parseFloat(blurPx) > 0.3 ? 'blur(' + blurPx + 'px)' : '';

      // Arcs
      arcs.forEach(function (arc) {
        updateArc(arc, dt, p);
        if (arc.wrap) arc.wrap.style.filter = blurVal;
      });

      // Orb: form then collapse
      updateOrb(p);

      // Shockwave on arrival
      checkShockwave(p);

      // Vector ring: fades out as orb becomes visible, fully gone by orbit phase
      if (orbVectorRing) orbVectorRing.style.opacity = (1 - pt(p, P_FLY_END, P_ORBIT_END)).toFixed(3);

      // Glow halo — always called so it clears itself when scrolling back
      updateChroma(p, arcs[0].angle);
    }

    requestAnimationFrame(tick);
  }

  requestAnimationFrame(function (ts) { lastTs = ts; requestAnimationFrame(tick); });
})();
</script>
